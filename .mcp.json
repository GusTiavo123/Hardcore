{
  "mcpServers": {
    "engram": {
      "type": "stdio",
      "command": "./tools/engram",
      "args": [
        "mcp"
      ],
      "env": {}
    },
    "open-websearch": {
      "type": "stdio",
      "command": "node",
      "args": [
        "./tools/node_modules/open-websearch/build/index.js"
      ],
      "env": {}
    },
    "domain-availability": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "imprvhub/mcp-domain-availability",
        "domain-mcp"
      ],
      "env": {}
    }
  }
}
